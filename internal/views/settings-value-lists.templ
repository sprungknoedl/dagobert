package views

import (
	"strings"

	"github.com/sprungknoedl/dagobert/internal/model"
	"github.com/sprungknoedl/dagobert/pkg/fp"
	"github.com/sprungknoedl/dagobert/pkg/valid"
)

templ SettingsValueListsMany(env Env) {
	@layout() {
		@list(env, "Value Lists", navSettings(), navHideAdd(), navHideExport(), navHideImport(), navHideSearch(), navSubtitle("Customisable value lists used across the app")) {
			<table class="table table-default">
				<thead>
					<tr>
						<th class="px-3 py-4 text-left">Rank</th>
						<th class="px-3 py-4 text-left">Name</th>
						<th class="px-3 py-4 text-left">Icon</th>
						<th class="px-3 py-4 text-left">State</th>
						<th style="width: 7rem"></th>
					</tr>
				</thead>
				@valueList(env, "Asset Status", env.ValueLists.AssetStatus)
				@valueList(env, "Asset Types", env.ValueLists.AssetTypes)
				@valueList(env, "Case Severities", env.ValueLists.CaseSeverities)
				@valueList(env, "Case Outcomes", env.ValueLists.CaseOutcomes)
				@valueList(env, "Event Types", env.ValueLists.EventTypes)
				@valueList(env, "Evidence Types", env.ValueLists.EvidenceTypes)
				@valueList(env, "Indicator Status", env.ValueLists.IndicatorStatus)
				@valueList(env, "Indicator Types", env.ValueLists.IndicatorTypes)
				@valueList(env, "Malware Status", env.ValueLists.MalwareStatus)
				@valueList(env, "Task Types", env.ValueLists.TaskTypes)
			</table>
		}
	}
}

templ SettingsValueListsOne(env Env, obj model.ValueListItem, vr valid.ValidationError) {
	{{ uri := "/settings/value-lists/" + obj.ID }}
	{{ title := fp.If(obj.ID == "new", "Add value", "Edit value") }}
	@form(env, uri, title) {
		@hiddenField("ID", obj.ID)
		@hiddenField("Category", obj.Category)
		@numberField("Rank", obj.Rank, withLabel("Rank"), withError(vr["Rank"]))
		@stringField("Name", obj.Name, required(), withLabel("Name"), withError(vr["Name"]))
		@stringField("Icon", obj.Icon, withLabel("Icon"), withError(vr["Icon"]), withHint("Phosphor icon class with the \"ph-\" prefix (e.g. \"ph-check-circle\", \"ph-x\"). Browse icons at phosphoricons.com."))
		<div class="form-control mb-2">
			<label class="label justify-start gap-2">
				State
				@validationError(vr["State"])
				<span class="tooltip tooltip-right" data-tip="Colour token used to render this value (e.g. &quot;success&quot;, &quot;warning&quot;, &quot;error&quot;, &quot;info&quot;). Leave empty for default text colour.">
					<i class="ph ph-4 ph-question text-base-content/40 cursor-help"></i>
				</span>
			</label>
			<select name="State" class="select w-full">
				<option disabled value="" selected?={ obj.State == "" }>Select an option</option>
				<option selected?={ obj.State == "success" }>success</option>
				<option selected?={ obj.State == "warning" }>warning</option>
				<option selected?={ obj.State == "danger" }>danger</option>
			</select>
		</div>
		@requiredFootnote()
	}
}

templ valueList(env Env, title string, rows []model.ValueListItem) {
	@settingsCategoryBand(env, title, "/settings/value-lists/new", "?category="+strings.ReplaceAll(title, " ", ""))
	<tbody class="values">
		if len(rows) == 0 {
			@emptyTable(env, "No values defined.", "Each category lists the values available in a drop-down elsewhere in the app. Add, remove, or reorder entries to match your organisation's taxonomy.")
		} else {
			for _, row := range rows {
				<tr class="row-hover">
					<td>{ row.Rank } </td>
					<td>
						if row.Name != "" {
							{ row.Name }
						} else {
							<em>&lt;Empty&gt;</em>
						}
					</td>
					<td><i class={ "ph ph-5 " + row.Icon }></i> { row.Icon } </td>
					<td><span class={ "text-" + row.State }>{ row.State } </span> </td>
					<td class="text-right">
						<div class="join">
							@defaultActionBtns(env, env.Route+row.ID)
						</div>
					</td>
				</tr>
			}
		}
	</tbody>
}

// settingsCategoryBand is a fleuron divider that doubles as a collapsible
// category heading: chevron + title + Add button, with a trailing fleuron rule.
// Clicking the band toggles the following <tbody> (see toggleCategory in dagobert.js).
templ settingsCategoryBand(env Env, title string, addRoute string, addQuery string) {
	<tbody>
		<tr class="cursor-pointer select-none [&>td]:border-b-0" data-toggle-category>
			<td colspan="100" class="pt-8 pb-2">
				<div class="flex items-center gap-3 text-base-content/30">
					<i class="ph ph-5 ph-caret-right chevron rotate-90 transition-transform text-base-content/60 inline-block"></i>
					<span class="text-lg font-serif text-base-content whitespace-nowrap">{ title }</span>
					@fleuron("flex-1")
					if url, ok := env.Allowed("POST", addRoute); ok {
						<a class="btn btn-sm btn-neutral" href={ url + addQuery } up-layer="new drawer" up-accept-location={ env.Route } data-stop-propagation>
							<i class="ph ph-5 ph-plus inline-block"></i> Add
						</a>
					}
				</div>
			</td>
		</tr>
	</tbody>
}
