#
# --- DAGOBERT WEB ---
#

# -- OpenID
# Set OIDC_ENABLED=true to show the "Sign in with SSO" button next to the
# local login form.
OIDC_ENABLED=false
OIDC_ISSUER=https://login.microsoftonline.com/TENANT_ID/v2.0
OIDC_CLIENT_ID=ClientIdIssuedById
OIDC_CLIENT_SECRET=SecretIssuedByIdp
# The IdP redirect URI is derived as <OIDC_CLIENT_URL>/auth/callback — register
# exactly that value in your IdP (e.g. the Azure AD app registration).
OIDC_CLIENT_URL=http://localhost:8080
# Token claim used as the stable user identity (Azure AD: oid). Existing users
# and per-case ACLs are keyed by this value — do not change it after first use.
OIDC_ID_CLAIM=oid
# When true, unknown users authenticating via OIDC are created automatically
# with no role (an administrator must assign one before they can do anything).
# When false, unknown users are rejected with 403.
OIDC_AUTO_PROVISION=false

# -- Web
# Session cookies are sent only over HTTPS by default. Set to false for local
# development over plain http://.
WEB_SECURE_COOKIE=true

# -- TimeSketch settings (also the entire configuration of the built-in
# -- Timesketch Importer job module; leave TIMESKETCH_URL unset to disable)
TIMESKETCH_URL=http://timesketch:8080
TIMESKETCH_USER=user
TIMESKETCH_PASS=password
TIMESKETCH_SKIP_VERIFY_TLS=false

#
# --- JOB MODULES ---
#

# -- Size of the in-process job runner pool
DAGOBERT_WORKERS=3

# The sprungknoedl/dagobert-full image presets the MODULE_* variables to the
# bundled tools. Leave them unset when using that image — values set here
# override the image's defaults and will break them.

# -- Module executables (local binaries, when the tools are on the PATH)
# MODULE_PLASO=psteal.py
# MODULE_HAYABUSA=hayabusa

# -- Module executables (docker, when running dagobert outside a container)
# MODULE_PLASO=docker run -v $PWD/files:/home/plaso/files log2timeline/plaso psteal
# MODULE_HAYABUSA=docker run -v $PWD/files:/home/sprungknoedl/files sprungknoedl/hayabusa